{
  "name": "terracotta.org-site",
  "private": true,
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/site.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/site.css --watch",
    "build": "npm run build:css && bundle exec jekyll build",
    "serve": "npm run build:css && bundle exec jekyll serve --livereload"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "prismjs": "^1.30.0"
  }
}
